RewriteEngine On
RewriteBase /

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.halldorophone\.info [NC]
RewriteRule ^ https://halldorophone.info%{REQUEST_URI} [R=301,L]

# Sitemap
Sitemap: https://halldorophone.info/sitemap.xml

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Rewrite all clean URLs to index.html
RewriteRule ^(.*)$ /index.html [L,QSA]
